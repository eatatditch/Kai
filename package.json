{
  "name": "ditch-marketing-os",
  "version": "0.1.0",
  "private": true,
  "description": "Internal marketing OS for the Ditch team — content generation, approval, scheduling, and analytics across all Ditch brand accounts.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "supabase db push",
    "db:types": "supabase gen types typescript --linked > types/database.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.451.0",
    "next": "14.2.15",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"

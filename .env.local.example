# Copy this file to .env.local and fill in real values for local development.
# Production / preview values live in Vercel project settings.
# Never commit .env.local — it is gitignored.

# Supabase (project URL + anon key are public; service role is server-only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (server-only)
ANTHROPIC_API_KEY=

# Klaviyo (server-only)
KLAVIYO_API_KEY=

# Meta Graph API (server-only)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# TikTok Content Posting API (server-only)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google Business Profile + Drive (server-only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Supabase — get these from https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the browser. Used in route handlers / server actions
# that need to bypass RLS (admin operations, webhooks).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — for Kai (Sonnet 4.6 drafting, Haiku 4.5 scoring)
ANTHROPIC_API_KEY=

# Klaviyo — email send engine
KLAVIYO_API_KEY=

# Meta Graph API — IG scheduling and insights
META_APP_ID=
META_APP_SECRET=

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google Business Profile API — review responses
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public site URL — used for auth callbacks and shareable links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

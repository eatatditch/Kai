    entries.forEach(e => {
      if (e.isIntersecting){
        [[e.target](http://e.target)](http://e.target).classList.add('in');
        io.unobserve([[e.target](http://e.target)](http://e.target));
      }
    });
  }, { threshold: 0.10 });
  els.forEach(el => io.observe(el));
</script>


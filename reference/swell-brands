<!-- SUPABASE — newsletter signups                                  -->
<!-- Replace the two values below with your project's credentials.  -->
<!-- Both values are public-safe (RLS protects the data).           -->
<!-- ============================================================== -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
  const SUPABASE_URL      = 'https://YOUR-PROJECT-ID.supabase.co';
  const SUPABASE_ANON_KEY = 'YOUR-PUBLIC-ANON-KEY';

  // only initialize if you've actually filled in the values
  let sb = null;
  if (window.supabase && !SUPABASE_URL.includes('YOUR-')) {
    sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  }

  async function handleSubscribe(e){
    e.preventDefault();
    const form   = [[e.target](http://e.target)](http://e.target);
    const input  = form.querySelector('input');
    const button = form.querySelector('button');
    const email  = input.value.trim().toLowerCase();
    if (!email) return;

    button.disabled    = true;
    button.textContent = 'sending...';

    // graceful fallback when supabase isn't wired up yet (e.g. local preview)
    if (!sb){
      setTimeout(() => {
        input.value = '';
        button.textContent = 'thanks!';
        button.disabled = false;
      }, 600);
      return;
    }

    const { error } = await sb
      .from('subscribers')
      .insert([{ email, source: '[[swellbrands.co](http://swellbrands.co)](http://swellbrands.co)' }]);

    // duplicate emails return an error — treat that as success
    const isDup = error && /duplicate|unique/i.test(error.message);
    if (error && !isDup){
      console.error('supabase error:', error);
      button.textContent = 'try again';
      button.disabled = false;
      return;
    }

    input.value = '';
    button.textContent = 'thanks!';
    setTimeout(() => {
      button.textContent = 'subscribe';
      button.disabled = false;
    }, 3000);
  }
</script>

